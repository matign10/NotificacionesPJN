# PJN Credentials (legacy — usados por el scraper Playwright)
PJN_USERNAME=tu_usuario_aqui
PJN_PASSWORD=tu_password_aqui

# PJN API (modo nuevo — obtener con `npm run bootstrap:token`)
PJN_CLIENT_ID=pjn-sne
PJN_REFRESH_TOKEN=

# Selector de motor de monitoreo: "api" (default) o "scraper" (legacy Playwright)
MONITOR_MODE=api

# Días hacia atrás a consultar en cada corrida (modo API)
LOOKBACK_DAYS=60

# Adjuntar PDF de la notificación al mensaje de Telegram (modo API)
ATTACH_PDF=true

# Supabase (necesario para el modo API)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Telegram Bot Configuration
# Para obtener el token: habla con @BotFather en Telegram
# Para obtener tu chat ID: habla con @userinfobot en Telegram
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# Application Configuration
CHECK_INTERVAL_MINUTES=30
HEADLESS_MODE=false
LOG_LEVEL=info

# WSL Display Configuration (para debugging con navegador visible)
# Si usas VcXsrv o similar, descomenta la siguiente línea
# DISPLAY=:0

# Paths (ajusta según tu configuración WSL)
DATA_DIR=/mnt/c/Users/matia/OneDrive/Escritorio/pjn-notificaciones-monitor/data
LOGS_DIR=/mnt/c/Users/matia/OneDrive/Escritorio/pjn-notificaciones-monitor/logs
