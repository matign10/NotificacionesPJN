# Supabase (donde persiste la DB y el refresh_token rotado)
# Usar service_role key: el monitor corre server-side y bypassea RLS.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Multi-usuario (recomendado) ───────────────────────────────────────
# Un JSON array; cada usuario PJN con su propio bot de Telegram. El "id" es
# el discriminador en la base (columna user_id) y en kv_config. pjnUsername/
# pjnPassword son opcionales (sólo para el auto-login del bootstrap).
# PJN_USERS=[{"id":"matias","pjnUsername":"20...","pjnPassword":"...","telegramBotToken":"123:ABC","telegramChatId":"111"},{"id":"user2","pjnUsername":"27...","pjnPassword":"...","telegramBotToken":"456:DEF","telegramChatId":"222"}]

# ─── Usuario único (legacy / fallback) ─────────────────────────────────
# Si NO definís PJN_USERS, el monitor arma un solo usuario (id "matias")
# desde estas vars. El refresh_token se siembra con `npm run bootstrap:token`.
PJN_USER_ID=matias
PJN_USERNAME=
PJN_PASSWORD=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behaviour
LOOKBACK_DAYS=60
ATTACH_PDF=true
LOG_LEVEL=info

# Para deshabilitar Telegram en pruebas locales (marca como enviada sin mandar)
# DISABLE_TELEGRAM=true
