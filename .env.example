# Supabase (donde persiste la DB y el refresh_token rotado)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=

# PJN — Keycloak / OIDC
# El refresh_token se obtiene con `npm run bootstrap:token` (login one-shot)
# y queda persistido automáticamente en Supabase. La var se mantiene como
# fallback para la primera corrida si Supabase está vacío.
PJN_CLIENT_ID=pjn-sne
PJN_REFRESH_TOKEN=

# (opcional, sólo para auto-login en el bootstrap)
PJN_USERNAME=
PJN_PASSWORD=

# Telegram Bot
# Token: hablar con @BotFather. Chat id: GET https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Behaviour
LOOKBACK_DAYS=60
ATTACH_PDF=true
LOG_LEVEL=info

# Para deshabilitar Telegram en pruebas locales (marca como enviada sin mandar)
# DISABLE_TELEGRAM=true
